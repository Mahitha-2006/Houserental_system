{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": [],
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["*.js", "models/**/*.js"],
  "exclude": ["node_modules"]
}
